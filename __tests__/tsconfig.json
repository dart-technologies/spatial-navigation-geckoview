{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "../globals.d.ts",
    "../main.ts",
    "../background.ts",
    "../core/**/*.ts",
    "../navigation/**/*.ts",
    "../utils/**/*.ts",
    "../src/**/*.ts",
    "./**/*.ts"
  ],
  "exclude": ["../node_modules", "../dist", "../extension", "../*.js"]
}
