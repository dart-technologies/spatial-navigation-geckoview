{
  "name": "@dart-technologies/spatial-navigation-geckoview",
  "version": "3.2.0",
  "description": "GeckoView web extension for D-pad/arrow key spatial navigation with WICG compatibility",
  "main": "dist/spatial-navigation.js",
  "module": "dist/spatial-navigation.esm.js",
  "types": "dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/spatial-navigation.esm.js",
      "require": "./dist/spatial-navigation.js",
      "types": "./dist/types/index.d.ts"
    },
    "./extension": {
      "default": "./extension/spatial_navigation.js"
    },
    "./extension/debug": {
      "default": "./extension/spatial_navigation.debug.js"
    },
    "./messaging": {
      "import": "./dist/messaging.esm.js",
      "require": "./dist/messaging.js",
      "types": "./dist/types/messaging/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.esm.js",
      "require": "./dist/core.js",
      "types": "./dist/types/core/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "extension/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "RELEASING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/rollup_build.mjs",
    "build:all": "npm run build && npm run sync:manifest",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "sync:manifest": "node scripts/sync-manifest-version.mjs",
    "release": "node scripts/release.mjs",
    "test": "NODE_ENV=test node --import tsx --test __tests__/*.test.ts",
    "test:watch": "NODE_ENV=test node --import tsx --test --watch __tests__/*.test.ts",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "test:visual:ui": "npx playwright test --ui",
    "test:benchmark": "node --import tsx --test perf/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html --reporter=cobertura --src=. --exclude='dist/**' --exclude='extension/**' --exclude='__tests__/**' --exclude='e2e/**' --exclude='perf/**' --exclude='*.config.{js,mjs,ts}' --exclude='scripts/**' --exclude='coverage/**' --exclude='node_modules/**' --reports-dir=coverage --check-coverage --lines=88 --functions=88 --statements=88 --branches=80 npm test",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p __tests__/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:check": "npm audit --omit=dev --audit-level=high",
    "size": "node scripts/check-bundle-size.mjs",
    "docs": "typedoc",
    "clean": "rm -rf dist/ coverage/",
    "prepublishOnly": "npm run clean && npm run build:all && npm run build:types",
    "prepare": "husky"
  },
  "type": "module",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{js,mjs,json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "geckoview",
    "spatial-navigation",
    "webextension",
    "android-tv",
    "aaos",
    "dpad",
    "arrow-keys",
    "focus-management",
    "tv-navigation",
    "wicg",
    "focus-groups",
    "scroll-snap",
    "shadow-dom"
  ],
  "author": "dart-technologies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dart-technologies/spatial-navigation-geckoview.git"
  },
  "bugs": {
    "url": "https://github.com/dart-technologies/spatial-navigation-geckoview/issues"
  },
  "homepage": "https://github.com/dart-technologies/spatial-navigation-geckoview#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup": "^4.61.1",
    "serve": "^14.2.5",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  }
}
